  "item": [
    {
      "name": "Scenario 1 - Successful Payment (Valid IBAN, Amount <= 1000)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Pre-request: set valid test data",
              "pm.variables.set('debtorIban',    'DE89370400440532013000');",
              "pm.variables.set('creditorIban',  'DE89770400440532013000');",
              "pm.variables.set('amount',        '150.75');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ── IBAN Validation Helper ─────────────────────────────────────────────",
              "function validateIban(iban) {",
              "    if (!iban || typeof iban !== 'string') return { valid: false, reason: 'IBAN is missing or not a string' };",
              "    if (iban.length !== 22)                return { valid: false, reason: 'IBAN must be exactly 22 characters, got ' + iban.length };",
              "    if (!/^[A-Z]{2}/.test(iban))           return { valid: false, reason: 'First 2 characters must be uppercase letters (A-Z)' };",
              "    if (!/^[A-Z]{2}[0-9]{2}/.test(iban))  return { valid: false, reason: 'Characters 3-4 must be digits (0-9)' };",
              "    if (!/^[A-Z]{2}[0-9]{2}[A-Z0-9]{18}$/.test(iban)) return { valid: false, reason: 'Characters 5-22 must be alphanumeric (A-Z, 0-9)' };",
              "    return { valid: true };",
              "}",
              "",
              "// ── Amount Validation Helper ───────────────────────────────────────────",
              "function validateAmount(amount) {",
              "    const parsed = parseFloat(amount);",
              "    if (isNaN(parsed)) return { valid: false, reason: 'Amount is not a valid number' };",
              "    if (parsed > 1000) return { valid: false, reason: 'Insufficient funds: amount exceeds 1000' };",
              "    return { valid: true, value: parsed };",
              "}",
              "",
              "// ── Read request body ──────────────────────────────────────────────────",
              "const body          = JSON.parse(pm.request.body.raw);",
              "const debtorIban    = body.debtorAccount.iban;",
              "const creditorIban  = body.creditorAccount.iban;",
              "const amount        = body.instructedAmount.amount;",
              "",
              "// ── Run validations ────────────────────────────────────────────────────",
              "const debtorResult   = validateIban(debtorIban);",
              "const creditorResult = validateIban(creditorIban);",
              "const amountResult   = validateAmount(amount);",
              "",
              "// ── IBAN Tests ─────────────────────────────────────────────────────────",
              "pm.test('Debtor IBAN is exactly 22 characters', () => {",
              "    pm.expect(debtorIban.length).to.equal(22);",
              "});",
              "pm.test('Debtor IBAN starts with 2 uppercase letters', () => {",
              "    pm.expect(debtorIban).to.match(/^[A-Z]{2}/);",
              "});",
              "pm.test('Debtor IBAN chars 3-4 are digits', () => {",
              "    pm.expect(debtorIban.substring(2, 4)).to.match(/^[0-9]{2}$/);",
              "});",
              "pm.test('Debtor IBAN chars 5-22 are alphanumeric', () => {",
              "    pm.expect(debtorIban.substring(4)).to.match(/^[A-Z0-9]{18}$/);",
              "});",
              "pm.test('Debtor IBAN has no spaces or special characters', () => {",
              "    pm.expect(debtorIban).to.match(/^[A-Z0-9]+$/);",
              "});",
              "pm.test('Creditor IBAN is valid (22 chars, correct format)', () => {",
              "    pm.expect(creditorResult.valid).to.be.true;",
              "});",
              "",
              "// ── Amount Tests ───────────────────────────────────────────────────────",
              "pm.test('Amount is <= 1000 (no insufficient funds)', () => {",
              "    pm.expect(parseFloat(amount)).to.be.at.most(1000);",
              "});",
              "",
              "// ── Response Tests ─────────────────────────────────────────────────────",
              "pm.test('Status code is 201 Created', () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response has transactionStatus RCVD', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.transactionStatus).to.equal('RCVD');",
              "});",
              "pm.test('Response has paymentId', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.paymentId).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Response has _links.self and _links.status', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json._links).to.have.property('self');",
              "    pm.expect(json._links).to.have.property('status');",
              "});",
              "pm.test('transactionFeeIndicator is boolean true', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.transactionFeeIndicator).to.equal(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Mock-Scenario", "value": "success" }
