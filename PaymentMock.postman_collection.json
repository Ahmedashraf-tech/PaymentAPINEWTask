          "body": "{\n  \"transactionStatus\": \"RCVD\",\n  \"paymentId\": \"PAY123456789\",\n  \"transactionFeeIndicator\": true,\n  \"_links\": {\n    \"self\": {\n      \"href\": \"/v1/payments/PAY123456789\"\n    },\n    \"status\": {\n      \"href\": \"/v1/payments/PAY123456789/status\"\n    }\n  }\n}"
        }
