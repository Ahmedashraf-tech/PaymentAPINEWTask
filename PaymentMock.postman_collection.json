            "exec": [
              "// Set invalid IBAN for testing",
              "pm.variables.set('invalidIban', 'DE123');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ── IBAN Validation Helper ─────────────────────────────────────────────",
              "function validateIban(iban) {",
              "    if (!iban || typeof iban !== 'string') return { valid: false, reason: 'IBAN is missing or not a string' };",
              "    if (iban.length !== 22)                return { valid: false, reason: 'IBAN must be exactly 22 characters, got ' + iban.length };",
              "    if (!/^[A-Z]{2}/.test(iban))           return { valid: false, reason: 'First 2 characters must be uppercase letters (A-Z)' };",
              "    if (!/^[A-Z]{2}[0-9]{2}/.test(iban))  return { valid: false, reason: 'Characters 3-4 must be digits (0-9)' };",
              "    if (!/^[A-Z]{2}[0-9]{2}[A-Z0-9]{18}$/.test(iban)) return { valid: false, reason: 'Characters 5-22 must be alphanumeric (A-Z, 0-9)' };",
              "    return { valid: true };",
              "}",
              "",
              "const body       = JSON.parse(pm.request.body.raw);",
              "const debtorIban = body.debtorAccount.iban;",
              "const result     = validateIban(debtorIban);",
              "",
              "// ── IBAN Failure Tests ─────────────────────────────────────────────────",
              "pm.test('Debtor IBAN is NOT 22 characters (invalid)', () => {",
