            "body": {
              "mode": "raw",
              "raw": "{\n  \"instructedAmount\": {\n    \"currency\": \"EUR\",\n    \"amount\": \"150.75\"\n  },\n  \"debtorAccount\": {\n    \"iban\": \"DE89370400440532013000\"\n  },\n  \"creditorAccount\": {\n    \"iban\": \"DE89770400440532013000\"\n  },\n  \"creditorName\": \"Amazon EU\",\n  \"remittanceInformationUnstructured\": \"Invoice #AMZ-2024-001\"\n}"
            },
            "url": {
