              "});",
              "pm.test('IBAN validation correctly detects invalid format', () => {",
              "    pm.expect(result.valid).to.be.false;",
              "});",
              "",
              "// ── Response Tests ─────────────────────────────────────────────────────",
              "pm.test('Status code is 422 Unprocessable Entity', () => {",
              "    pm.response.to.have.status(422);",
              "});",
              "pm.test('Response type is INVALID_IBAN_FORMAT', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.type).to.equal('INVALID_IBAN_FORMAT');",
              "});",
              "pm.test('Response status field equals 422', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.equal(422);",
              "});",
              "pm.test('Response contains validationRules', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.validationRules).to.be.an('object');",
              "    pm.expect(json.validationRules.totalLength).to.equal(22);",
              "});",
              "pm.test('Response contains invalidFields array', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.invalidFields).to.be.an('array').with.length.greaterThan(0);",
              "});",
              "pm.test('invalidFields contains debtorAccount.iban', () => {",
              "    const json   = pm.response.json();",
              "    const fields = json.invalidFields.map(f => f.field);",
              "    pm.expect(fields).to.include('debtorAccount.iban');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
